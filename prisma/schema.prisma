// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/infrastructure/prisma/generated"
}

datasource db {
  provider = "postgresql"
  schemas  = ["applications_service"]
}

model Application {
  id                String            @id @unique
  dogId             String
  applicantId       String
  shelterId         String
  status            ApplicationStatus
  shelterComments   String?           @db.Text
  applicantComments String?           @db.Text

  createdAt DateTime
  updatedAt DateTime

  @@schema("applications_service")
}

enum ApplicationStatus {
  pending
  approved
  rejected

  @@schema("applications_service")
}

model Applicant {
  id         String  @id @unique
  userId     String  @unique
  userName   String
  address    String
  postalCode String
  phone      String?
  email      String?
  avatarUrl  String?
  vector     Float[]

  createdAt DateTime
  updatedAt DateTime

  @@schema("applications_service")
}
